# Copy to `.env` for local `netlify dev`, and set the same keys in the Netlify
# dashboard (Site settings -> Environment variables) for production.

# Supabase Postgres connection string. Use the *Transaction pooler* string
# (host ends in `.pooler.supabase.com`, port 6543) — Supabase dashboard:
# Project Settings -> Database -> Connection string -> "Transaction" mode.
# Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres

# The first account registered under this exact username becomes superadmin.
# (Was `vars.ADMIN_USER` in wrangler.jsonc.)
ADMIN_USER=yue

# Minutes offset from UTC for the daily leaderboard reset. 480 = UTC+8.
# (Was `vars.TZ_OFFSET_MINUTES` in wrangler.jsonc.)
TZ_OFFSET_MINUTES=480
